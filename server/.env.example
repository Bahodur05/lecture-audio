# Public IP/hostname the WebRTC transport advertises to clients.
# Required in production — without it, ICE negotiation will fail for any
# client not on the exact same machine as the server.
ANNOUNCED_IP=

# UDP port range mediasoup uses for actual audio transport.
# Check your host's docs for any restrictions on this range.
RTC_MIN_PORT=40000
RTC_MAX_PORT=40100

PORT=3000
NODE_ENV=production
